{
  "name": "LocalPass",
  "short_name": "LocalPass",
  "description": "Your AI travel assistant for China — itinerary planning, food recommendations, and transportation guides.",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#0D9488",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "handle_links": "preferred",
  "categories": [
    "travel",
    "lifestyle",
    "navigation"
  ],
  "shortcuts": [
    {
      "name": "Plan a Trip",
      "short_name": "Trips",
      "description": "Plan your China trip with AI",
      "url": "/?tab=trips",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Food Guide",
