# =============================================================================
# Sentry 监控配置
# =============================================================================
# Sentry DSN (Data Source Name) - 从 https://sentry.io 获取
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# 应用版本号（用于 release tracking）
NEXT_PUBLIC_SENTRY_RELEASE=1.0.0

# Sentry 组织名称（可选，用于 source maps 上传）
SENTRY_ORG=your-org

# Sentry 项目名称（可选，用于 source maps 上传）
SENTRY_PROJECT=pwa

# Sentry Auth Token（仅用于构建时上传 source maps）
SENTRY_AUTH_TOKEN=your-auth-token

# 禁用服务端/客户端插件（可选）
# DISABLE_SENTRY_SERVER_PLUGIN=true
# DISABLE_SENTRY_CLIENT_PLUGIN=true

# =============================================================================
# 应用配置
# =============================================================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME="China Landing AI Helper"

# =============================================================================
# MiniMax AI 配置 (主 AI)
# =============================================================================
# 服务端专用，禁止暴露到客户端
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_MAX_TOKENS=1500

# =============================================================================
# Qwen AI 配置 (阿里云百炼 - 备用 AI)
# =============================================================================
# 获取方式：https://bailian.console.aliyun.com/
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_MAX_TOKENS=1500
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# Upstash Redis 配置（速率限制）
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# Supabase 配置
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# NextAuth 配置
# =============================================================================
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret

# Google OAuth (https://console.cloud.google.com/)
# 重定向 URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (https://developers.facebook.com/)
# 重定向 URI: https://your-app.vercel.app/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# OpenAI OAuth (https://platform.openai.com/)
# 重定向 URI: https://your-app.vercel.app/api/auth/callback/openai
OPENAI_CLIENT_ID=your-openai-client-id
OPENAI_CLIENT_SECRET=your-openai-client-secret

# 邮箱服务配置 (Magic Link 登录)
# 推荐使用 SendGrid: https://sendgrid.com/
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@your-app.vercel.app

# =============================================================================
# 日志配置（可选）
# =============================================================================
# 外部日志服务端点
# NEXT_PUBLIC_LOG_ENDPOINT=https://your-log-service.com/api/logs

# 分析服务端点
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics.com/api/collect

# =============================================================================
# 告警通知配置（钉钉/飞书）
# =============================================================================
# 钉钉机器人 Webhook（获取方式：钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义）
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 钉钉加签密钥（可选，增强安全性）
# DINGTALK_SECRET=xxx

# 飞书机器人 Webhook（获取方式：飞书群 → 群设置 → 机器人 → 添加自定义机器人）
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 告警 Webhook 认证 Token（用于 /api/alerts/webhook 端点）
# ALERT_WEBHOOK_TOKEN=your-secret-token

# =============================================================================
# 其他配置
# =============================================================================
# Node 环境
NODE_ENV=development

# 分析模式（启用 bundle 分析）
# ANALYZE=true
