# Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or .env.production to version control

# ============================================================================
# NextAuth Configuration
# ============================================================================
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ============================================================================
# Email Configuration (SendGrid recommended)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# ============================================================================
EMAIL_SERVER="smtp://apikey:your-sendgrid-api-key@smtp.sendgrid.net:587"
EMAIL_FROM="noreply@yourdomain.com"

# ============================================================================
# OAuth Providers (Optional - leave empty if not using)
# ============================================================================

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# OpenAI OAuth (if needed)
OPENAI_CLIENT_ID=""
OPENAI_CLIENT_SECRET=""

# ============================================================================
# AI Model Providers
# ============================================================================

# MiniMax AI: https://api.minimaxi.com/
MINIMAX_API_KEY=""
MINIMAX_MAX_TOKENS="1500"
MINIMAX_MODEL="MiniMax-M2.7"

# Qwen (Alibaba Cloud Bailian): https://dashscope.console.aliyun.com/
QWEN_API_KEY=""
QWEN_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MAX_TOKENS="1500"
QWEN_MODEL="qwen-plus"

# ============================================================================
# Redis (Upstash - for rate limiting)
# Get from: https://console.upstash.com/
# ============================================================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ============================================================================
# Monitoring & Error Tracking (Sentry)
# Get DSN from: https://sentry.io/settings/your-org/projects/your-project/keys/
# ============================================================================
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_RELEASE="1.0.0-beta"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"

# ============================================================================
# Notifications (Optional)
# ============================================================================

# Feishu/Lark Bot: https://open.feishu.cn/document/ukTMukTMukTM/ucTM5YjL3ETOq4yNxkjN
FEISHU_WEBHOOK=""

# DingTalk Bot (optional)
# DINGTALK_WEBHOOK=""
# DINGTALK_SECRET=""

# ============================================================================
# Application Configuration
# ============================================================================
NEXT_PUBLIC_APP_NAME="China Landing AI Helper"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# Vercel Configuration (Auto-set in production, override locally if needed)
# ============================================================================
VERCEL="1"
VERCEL_ENV="development"
VERCEL_URL=""

# ============================================================================
# Build Tools Configuration
# ============================================================================
NX_DAEMON="false"
TURBO_CACHE="remote:rw"
TURBO_DOWNLOAD_LOCAL_ENABLED="true"
TURBO_REMOTE_ONLY="true"
TURBO_RUN_SUMMARY="true"

# =============================================================================
# 🤖 Telegram Bot
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
