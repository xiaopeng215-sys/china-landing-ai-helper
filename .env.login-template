# 并替换所有 <xxx> 占位符为实际值
# =============================================================================

# =============================================================================
# NextAuth 核心配置
# =============================================================================
NEXTAUTH_URL=https://china-landing-ai-helper.vercel.app

# 生成方法：openssl rand -base64 32
# 或使用：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=<替换为你的 32 位随机字符串>

# =============================================================================
# Supabase 数据库配置 (必需)
# 获取方式：https://app.supabase.com/project/_/settings/api
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# =============================================================================
