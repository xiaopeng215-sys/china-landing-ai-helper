# Production Environment Variables - Configure in Vercel Dashboard

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL="https://china-landing-ai-helper.vercel.app"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Email (SendGrid)
EMAIL_SERVER="smtp://apikey:your-sendgrid-api-key@smtp.sendgrid.net:587"
EMAIL_FROM="noreply@china-landing-ai-helper.vercel.app"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
OPENAI_CLIENT_ID=""
OPENAI_CLIENT_SECRET=""

# AI Providers
MINIMAX_API_KEY=""
MINIMAX_MAX_TOKENS="1500"
MINIMAX_MODEL="MiniMax-M2.7"
QWEN_API_KEY=""
QWEN_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MAX_TOKENS="1500"
QWEN_MODEL="qwen-plus"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_RELEASE="1.0.0-beta"
SENTRY_ORG="gbhenry"
SENTRY_PROJECT="pwa"

# Notifications
FEISHU_WEBHOOK=""

# App Config
NEXT_PUBLIC_APP_NAME="China Landing AI Helper"
NEXT_PUBLIC_APP_URL="https://china-landing-ai-helper.vercel.app"
NODE_ENV="production"

# Vercel (Auto-set by Vercel)
VERCEL="1"
VERCEL_ENV="production"
VERCEL_URL=""
VERCEL_GIT_COMMIT_AUTHOR_LOGIN=""
VERCEL_GIT_COMMIT_AUTHOR_NAME=""
VERCEL_GIT_COMMIT_MESSAGE=""
VERCEL_GIT_COMMIT_REF=""
VERCEL_GIT_COMMIT_SHA=""
VERCEL_GIT_PREVIOUS_SHA=""
VERCEL_GIT_PROVIDER=""
VERCEL_GIT_PULL_REQUEST_ID=""
VERCEL_GIT_REPO_ID=""
VERCEL_GIT_REPO_OWNER=""
VERCEL_GIT_REPO_SLUG=""
VERCEL_OIDC_TOKEN=""
VERCEL_TARGET_ENV="production"

# Build Tools
NX_DAEMON="false"
TURBO_CACHE="remote:rw"
TURBO_DOWNLOAD_LOCAL_ENABLED="true"
TURBO_REMOTE_ONLY="true"
TURBO_RUN_SUMMARY="true"
